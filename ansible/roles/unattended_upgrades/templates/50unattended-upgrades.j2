Unattended-Upgrade::Origins-Pattern {
{% for origin in unattended_origins %}
        "origin={{ origin }}";
{% endfor %}
};

Unattended-Upgrade::Automatic-Reboot "{{ unattended_auto_reboot | lower }}";
Unattended-Upgrade::Automatic-Reboot-Time "{{ unattended_auto_reboot_time }}";

Unattended-Upgrade::Remove-Unused-Dependencies "true";
Unattended-Upgrade::Remove-New-Unused-Dependencies "true";